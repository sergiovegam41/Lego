# Url publica
HOST_NAME=https://example.com

# Configuración de PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_DATABASE=lego-postgresql-db
DB_USERNAME=lego # no definir `root` como nombre de usuario
DB_PASSWORD=1224

# Configuración de pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8081

# Configuración de MongoDB
MONGO_DB_HOST=mongodb
MONGO_DB_PORT=27017
MONGO_DB_DATABASE=lego-mongo-db
MONGO_DB_USERNAME=lego
MONGO_DB_PASSWORD=1224

# Configuración de Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=lego
REDIS_PASSWORD=1224

# Configuración de Jwt
JWT_SECRET=1224

# Identificadores de usuario
UID=1000
GID=1000

# Configuración de n8n
N8N_ENABLED=true
N8N_LOCAL_INSTANCE=true

# Configuración de n8n Local
N8N_PORT=5678
N8N_PROTOCOL=http
DOMAIN_NAME=n8n.lego.ondeploy.space
N8N_ENCRYPTION_KEY=your-secret-key-min-32-characters
NODE_ENV=production

# Base de datos para n8n (PostgreSQL)
N8N_DB_TYPE=postgresdb
N8N_DB_HOST=db
N8N_DB_DATABASE=n8n
N8N_DB_USER=lego
N8N_DB_PASSWORD=1224
N8N_DB_PORT=5432
GENERIC_TIMEZONE=UTC

# Configuración de n8n Externo (usado cuando N8N_LOCAL_INSTANCE=false)
N8N_EXTERNAL_URL=https://your-n8n-instance.com
N8N_EXTERNAL_API_KEY=your-api-key

# LLM provider para `php lego docs:graph --with-descriptions`
# Genera descripciones automáticas de cada clase con LLM.
# Valores: ollama | groq
LLM_PROVIDER=ollama

# Ollama (local, gratis, sin rate limits)
# Requiere: instalar Ollama (https://ollama.com), activar "Expose Ollama to the network",
# y descargar el modelo: `ollama pull qwen2.5-coder:14b`
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# Groq (cloud, free tier limitado)
# Crear API key en https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

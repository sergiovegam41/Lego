{
    "require": {
        "mikecao/flight": "^3.13",
        "illuminate/database": "^11.33",
        "illuminate/pagination": "^11.33",
        "vlucas/phpdotenv": "^5.6",
        "rakit/validation": "^1.4",
        "laravel/serializable-closure": "^2.0",
        "firebase/php-jwt": "^6.11",
        "nesbot/carbon": "^3.8",
        "predis/predis": "^2.3",
        "intervention/image": "^2.7",
        "aws/aws-sdk-php": "^3.0",
        "nikic/php-parser": "^5.3"
    },
    "autoload": {
        "psr-4": {
          "App\\": "App/",
          "Core\\": "Core/",
          "public\\":"public/",
          "Components\\":"components/"
        },
        "files": [
          "components/shared/Forms/Forms.php",
          "components/shared/Essentials/Essentials.php",
          "components/shared/Buttons/Buttons.php",
          "components/shared/Navigation/Navigation.php"
        ]
      },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "php scripts/generate-ide-helpers.php",
        "test": "vendor/bin/pest",
        "test:unit": "vendor/bin/pest --testsuite=Unit",
        "test:arch": "vendor/bin/pest --testsuite=Architecture"
    },
    "require-dev": {
        "pestphp/pest": "*",
        "pestphp/pest-plugin-arch": "*"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
